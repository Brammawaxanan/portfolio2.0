APP_ENV=local
APP_DEBUG=false
APP_KEY=change-this-to-a-random-secret

# Frontend contact endpoint. Use the absolute PHP backend URL when frontend and backend are deployed separately.
VITE_CONTACT_API_URL=/api/contact

# Do not commit real credentials. Copy this file to .env locally and set the real Atlas URI there.
MONGODB_URI=mongodb+srv://SBWaxan_3681:SBWaxan_3681@cluster0.h0xlqoh.mongodb.net/?appName=Cluster0
MONGODB_DATABASE=portfolio
MONGODB_CONTACT_COLLECTION=messages

# Comma-separated origins allowed to call the PHP API.
# Use your deployed frontend URL in production, for example:
# CORS_ALLOWED_ORIGINS=https://your-portfolio.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
